generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model TeamMember {
  id          String   @id
  name        String
  role        String
  education   String
  location    String
  mobile      String
  photo       String
  status      Int
  showHome    Int
  createdAt   DateTime @default(now())
  description String?  @default("")
}

model Complaint {
  id            String   @id @default(uuid())
  name          String
  mobile        String
  email         String?
  grievanceType String
  details       String
  status        String   @default("Pending")
  createdAt     DateTime @default(now())
}

model Enrollment {
  id        String   @id @default(uuid())
  name      String
  mobile    String
  email     String?
  courseId  String
  status    String   @default("Pending")
  createdAt DateTime @default(now())
}

model certificates {
  id                   String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  certificate_no       String               @unique @db.VarChar(100)
  registration_id      String               @db.Uuid
  user_name            String               @db.VarChar(255)
  course_name          String               @db.VarChar(255)
  issue_date           DateTime             @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  status               certificate_status   @default(VALID)
  pdf_url              String
  qr_code_url          String
  grade                String?              @db.VarChar(50)
  performance          String?              @db.VarChar(100)
  venue                String?              @db.VarChar(255)
  duration_from        String?              @db.VarChar(50)
  duration_to          String?              @db.VarChar(50)
  created_at           DateTime             @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at           DateTime             @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  course_registrations course_registrations @relation(fields: [registration_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([certificate_no], map: "idx_certificates_no")
}

model complaint_attachments {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  complaint_id String     @db.Uuid
  file_url     String
  file_name    String     @db.VarChar(255)
  file_size    String?    @db.VarChar(50)
  created_at   DateTime   @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  complaints   complaints @relation(fields: [complaint_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model complaints {
  id                    String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  complaint_no          String                  @unique @db.VarChar(100)
  user_id               String?                 @db.Uuid
  name                  String                  @db.VarChar(255)
  father_name           String                  @db.VarChar(255)
  gender                String                  @db.VarChar(50)
  mobile                String                  @db.VarChar(15)
  email                 String?                 @db.VarChar(255)
  address               String
  state                 String                  @db.VarChar(100)
  district              String                  @db.VarChar(100)
  police_station        String                  @db.VarChar(100)
  details               String
  status                complaint_status        @default(SUBMITTED)
  created_at            DateTime                @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at            DateTime                @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  complaint_attachments complaint_attachments[]
  users                 users?                  @relation(fields: [user_id], references: [id], onUpdate: NoAction)
  status_logs           status_logs[]

  @@index([complaint_no], map: "idx_complaints_no")
}

model course_registrations {
  id                                            String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  enrollment_no                                 String?           @unique @db.VarChar(100)
  user_id                                       String            @db.Uuid
  course_id                                     String            @db.Uuid
  full_name                                     String            @db.VarChar(255)
  mobile                                        String            @db.VarChar(15)
  email                                         String            @db.VarChar(255)
  father_name                                   String?           @db.VarChar(255)
  photo_url                                     String?
  status                                        enrollment_status @default(PENDING)
  approved_by                                   String?           @db.Uuid
  approved_at                                   DateTime?         @db.Timestamptz(6)
  remarks                                       String?
  created_at                                    DateTime          @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at                                    DateTime          @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  certificates                                  certificates[]
  users_course_registrations_approved_byTousers users?            @relation("course_registrations_approved_byTousers", fields: [approved_by], references: [id], onUpdate: NoAction)
  courses                                       courses           @relation(fields: [course_id], references: [id], onUpdate: NoAction)
  users_course_registrations_user_idTousers     users             @relation("course_registrations_user_idTousers", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  payments                                      payments[]
  status_logs                                   status_logs[]

  @@index([enrollment_no], map: "idx_registrations_no")
}

model courses {
  id                   String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title                String                 @db.VarChar(255)
  description          String
  duration             String                 @db.VarChar(50)
  fees                 Decimal                @db.Decimal(10, 2)
  eligibility          String                 @db.VarChar(255)
  image_url            String?
  is_active            Boolean                @default(true)
  created_at           DateTime               @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at           DateTime               @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  course_registrations course_registrations[]
}

model documents {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title      String   @db.VarChar(255)
  category   String   @db.VarChar(50)
  file_url   String
  file_size  String   @db.VarChar(50)
  is_active  Boolean  @default(true)
  created_at DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
}

model memberships {
  id                                   String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  membership_no                        String?           @unique @db.VarChar(100)
  ack_no                               String            @unique @db.VarChar(100)
  user_id                              String            @db.Uuid
  full_name                            String            @db.VarChar(255)
  father_name                          String            @db.VarChar(255)
  gender                               String            @db.VarChar(50)
  dob                                  DateTime          @db.Date
  mobile                               String            @db.VarChar(15)
  whatsapp                             String            @db.VarChar(15)
  email                                String            @db.VarChar(255)
  address                              String
  district                             String            @db.VarChar(100)
  state                                String            @db.VarChar(100)
  pincode                              String            @db.VarChar(10)
  education                            String            @db.VarChar(255)
  profession                           String            @db.VarChar(255)
  working_area                         String            @db.VarChar(255)
  designation                          String            @db.VarChar(255)
  police_station                       String?           @db.VarChar(255)
  photo_url                            String
  aadhaar_url                          String
  signature_url                        String
  status                               membership_status @default(PENDING)
  approved_by                          String?           @db.Uuid
  approved_at                          DateTime?         @db.Timestamptz(6)
  remarks                              String?
  created_at                           DateTime          @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at                           DateTime          @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  users_memberships_approved_byTousers users?            @relation("memberships_approved_byTousers", fields: [approved_by], references: [id], onUpdate: NoAction)
  users_memberships_user_idTousers     users             @relation("memberships_user_idTousers", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  payments                             payments[]
  status_logs                          status_logs[]

  @@index([ack_no], map: "idx_memberships_ack")
  @@index([membership_no], map: "idx_memberships_no")
}

model news {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title        String   @db.VarChar(255)
  slug         String   @unique @db.VarChar(255)
  content      String
  image_url    String?
  category     String?  @db.VarChar(100)
  is_published Boolean  @default(true)
  created_at   DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at   DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
}

model notification_templates {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String   @unique @db.VarChar(255)
  subject    String?  @db.VarChar(255)
  body       String
  created_at DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
}

model notifications {
  id        String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id   String?           @db.Uuid
  type      notification_type
  recipient String            @db.VarChar(255)
  subject   String?           @db.VarChar(255)
  body      String
  sent_at   DateTime          @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  success   Boolean           @default(true)
  users     users?            @relation(fields: [user_id], references: [id], onUpdate: NoAction)
}

model otp_requests {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  mobile     String   @db.VarChar(15)
  email      String?  @db.VarChar(255)
  otp_code   String   @db.VarChar(6)
  expires_at DateTime @db.Timestamptz(6)
  verified   Boolean  @default(false)
  created_at DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
}

model payments {
  id                      String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  amount                  Decimal                @db.Decimal(10, 2)
  transaction_id          String                 @unique @db.VarChar(255)
  gateway                 String                 @db.VarChar(50)
  gateway_transaction_id  String?                @db.VarChar(255)
  status                  String                 @db.VarChar(50)
  membership_id           String?                @db.Uuid
  registration_id         String?                @db.Uuid
  donation_id             String?                @db.Uuid
  appreciation_id         String?                @db.Uuid
  created_at              DateTime               @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  memberships             memberships?           @relation(fields: [membership_id], references: [id], onUpdate: NoAction)
  course_registrations    course_registrations?  @relation(fields: [registration_id], references: [id], onUpdate: NoAction)
  donations               donations?             @relation(fields: [donation_id], references: [id], onUpdate: NoAction)
  appreciation_applications appreciation_applications? @relation(fields: [appreciation_id], references: [id], onUpdate: NoAction)
}

model prefixes_counter {
  key        String @id @db.VarChar(50)
  year       Int
  last_value Int    @default(0)
}

model settings {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key         String   @unique @db.VarChar(255)
  value       String
  description String?
  updated_at  DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
}

model site_content {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key         String   @unique @db.VarChar(255)
  content     Json
  description String?
  updated_at  DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
}

model status_logs {
  id                   String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  membership_id        String?               @db.Uuid
  complaint_id         String?               @db.Uuid
  registration_id      String?               @db.Uuid
  appreciation_id      String?               @db.Uuid
  from_status          String                @db.VarChar(50)
  to_status            String                @db.VarChar(50)
  remarks              String?
  updated_by           String?               @db.Uuid
  created_at           DateTime              @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  complaints           complaints?           @relation(fields: [complaint_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  memberships          memberships?          @relation(fields: [membership_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  course_registrations course_registrations? @relation(fields: [registration_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  appreciation_applications appreciation_applications? @relation(fields: [appreciation_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users                users?                @relation(fields: [updated_by], references: [id], onUpdate: NoAction)
}

model users {
  id                                                           String                 @id @db.Uuid
  email                                                        String                 @unique @db.VarChar(255)
  role                                                         user_role              @default(USER)
  full_name                                                    String?                @db.VarChar(255)
  created_at                                                   DateTime               @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at                                                   DateTime               @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  complaints                                                   complaints[]
  course_registrations_course_registrations_approved_byTousers course_registrations[] @relation("course_registrations_approved_byTousers")
  course_registrations_course_registrations_user_idTousers     course_registrations[] @relation("course_registrations_user_idTousers")
  memberships_memberships_approved_byTousers                   memberships[]          @relation("memberships_approved_byTousers")
  memberships_memberships_user_idTousers                       memberships[]          @relation("memberships_user_idTousers")
  notifications                                                notifications[]
  status_logs                                                  status_logs[]
  appreciation_approved_by                                     appreciation_applications[] @relation("appreciation_approved_byTousers")
  appreciation_user_id                                         appreciation_applications[] @relation("appreciation_user_idTousers")
}

model Banner {
  id        String   @id @default(uuid())
  imageUrl  String
  title     String?  @default("")
  subtitle  String?  @default("")
  linkUrl   String?  @default("")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

enum certificate_status {
  VALID
  REVOKED
}

enum complaint_status {
  SUBMITTED
  UNDER_INVESTIGATION
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum enrollment_status {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

enum membership_status {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
}

enum notification_type {
  EMAIL
  SMS
  WHATSAPP
}

enum user_role {
  USER
  ADMIN
  SUPERADMIN
}

model donations {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id       String   @unique @db.VarChar(100)
  transaction_id String?  @db.VarChar(100)
  donor_name     String   @db.VarChar(255)
  donor_email    String   @db.VarChar(255)
  donor_mobile   String   @db.VarChar(15)
  donor_address  String
  amount         Decimal  @db.Decimal(10, 2)
  purpose        String   @default("General Donation") @db.VarChar(100)
  status         String   @default("PENDING") @db.VarChar(50)
  created_at     DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at     DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  payments       payments[]
}

model appreciation_applications {
  id                    String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  application_no        String        @unique @db.VarChar(100)
  user_id               String        @db.Uuid
  full_name             String        @db.VarChar(255)
  email                 String        @db.VarChar(255)
  mobile                String        @db.VarChar(20)
  address               String
  country               String        @db.VarChar(100)
  state                 String        @db.VarChar(100)
  district              String        @db.VarChar(100)
  pincode               String        @db.VarChar(20)
  social_work_field     String        @db.VarChar(255)
  description           String
  photo_url             String
  id_proof_url          String
  achievement_proof_url String?
  status                String        @default("PENDING") @db.VarChar(50)
  approved_by           String?       @db.Uuid
  approved_at           DateTime?     @db.Timestamptz(6)
  remarks               String?
  created_at            DateTime      @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at            DateTime      @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  payments              payments[]
  status_logs           status_logs[]
  users_appreciation_approved_byTousers users? @relation("appreciation_approved_byTousers", fields: [approved_by], references: [id], onUpdate: NoAction)
  users_appreciation_user_idTousers     users  @relation("appreciation_user_idTousers", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([application_no], map: "idx_appreciation_no")
}
