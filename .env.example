# =========================================================================
# DKFFJ NGO & ACADEMY PORTAL - ENVIRONMENT TEMPLATE
# Copy this file to .env (for server keys) and .env.local (for client keys)
# =========================================================================

# 1. Supabase PostgreSQL Connections
# Connect to Postgres via the transaction-mode pooler (for Prisma / general queries)
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-1-ap-southeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"

# Connect to Postgres via the direct session-mode pooler (for migrations & trigger setups)
DIRECT_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-1-ap-southeast-2.pooler.supabase.com:5432/postgres?sslmode=require"

# 2. Supabase API Configuration
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="YOUR_SUPABASE_ANON_KEY"

# 3. Email API Key (Resend Service)
RESEND_API_KEY="re_yourApiKeyHere"

# 4. App URL (Used for generating absolute links in emails/documents)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
